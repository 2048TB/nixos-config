{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nixos-config host registry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nixos": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    },
    "darwin": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "profiles",
        "deployEnabled"
      ],
      "properties": {
        "system": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "desktop",
              "laptop",
              "server"
            ]
          }
        },
        "deployEnabled": {
          "type": "boolean"
        },
        "deployHost": {
          "type": "string",
          "minLength": 1
        },
        "deployUser": {
          "type": "string",
          "minLength": 1
        },
        "deployPort": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
