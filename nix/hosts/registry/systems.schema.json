{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nixos-config host registry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nixos": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    },
    "darwin": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "desktopSession",
        "desktopProfile",
        "deployEnabled",
        "kind",
        "formFactor",
        "tags",
        "gpuVendors",
        "displays"
      ],
      "properties": {
        "system": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "desktopSession": {
          "type": "boolean"
        },
        "desktopProfile": {
          "type": "string",
          "enum": [
            "none",
            "river",
            "aqua"
          ]
        },
        "deployEnabled": {
          "type": "boolean"
        },
        "deployHost": {
          "type": "string",
          "minLength": 1
        },
        "deployUser": {
          "type": "string",
          "minLength": 1
        },
        "deployPort": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "workstation",
            "server",
            "vm"
          ]
        },
        "formFactor": {
          "type": "string",
          "enum": [
            "desktop",
            "laptop",
            "handheld",
            "headless"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "fingerprint-reader",
              "docked"
            ]
          }
        },
        "gpuVendors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "amd",
              "intel",
              "nvidia"
            ]
          }
        },
        "displays": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "match": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "width": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              },
              "height": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              },
              "refresh": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 1
              },
              "scale": {
                "type": [
                  "number",
                  "null"
                ],
                "exclusiveMinimum": 0
              },
              "primary": {
                "type": "boolean"
              },
              "workspaceSet": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
