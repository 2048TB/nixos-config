{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nixos-config host registry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nixos": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    },
    "darwin": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "desktopSession",
        "deployEnabled",
        "kind",
        "formFactor",
        "tags",
        "gpuVendors"
      ],
      "properties": {
        "system": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "desktopSession": {
          "type": "boolean"
        },
        "deployEnabled": {
          "type": "boolean"
        },
        "deployHost": {
          "type": "string",
          "minLength": 1
        },
        "deployUser": {
          "type": "string",
          "minLength": 1
        },
        "deployPort": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "workstation",
            "server",
            "vm"
          ]
        },
        "formFactor": {
          "type": "string",
          "enum": [
            "desktop",
            "laptop",
            "handheld",
            "headless"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gpuVendors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "amd",
              "intel",
              "nvidia"
            ]
          }
        }
      }
    }
  }
}
