keybinds {
    // Shared leader: Ctrl+b (same as tmux prefix)
    shared_except "tmux" "locked" {
        bind "Ctrl b" { SwitchToMode "Tmux"; }
    }
    tmux clear-defaults=true {
        bind "Ctrl b" { Write 2; SwitchToMode "Normal"; }

        // Pane focus (arrow keys, same as tmux)
        bind "Left" { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "Down" { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "Up" { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "Right" { MoveFocus "Right"; SwitchToMode "Normal"; }

        // Pane resize (h/j/k/l, aligned with tmux)
        bind "h" { Resize "Increase Left"; SwitchToMode "Normal"; }
        bind "j" { Resize "Increase Down"; SwitchToMode "Normal"; }
        bind "k" { Resize "Increase Up"; SwitchToMode "Normal"; }
        bind "l" { Resize "Increase Right"; SwitchToMode "Normal"; }

        // Pane and tab management
        bind "w" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "e" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "q" { CloseFocus; SwitchToMode "Normal"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "c" { NewTab; SwitchToMode "Normal"; }
        bind "d" { GoToNextTab; SwitchToMode "Normal"; }
        bind "s" { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "Tab" { ToggleTab; SwitchToMode "Normal"; }
        bind "t" { TogglePaneFrames; SwitchToMode "Normal"; }
        bind "F" {
            LaunchOrFocusPlugin "session-manager" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal";
        }
        bind "r" {
            LaunchOrFocusPlugin "configuration" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal";
        }
        bind "g" { Detach; SwitchToMode "Normal"; }
    }
}

default_shell "zsh"
pane_frames true
theme "default"
