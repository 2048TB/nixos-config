keybinds {
    // Shared leader: Ctrl+b (same as tmux prefix)
    shared_except "tmux" "locked" {
        bind "Ctrl b" { SwitchToMode "Tmux"; }
    }
    tmux clear-defaults=true {
        bind "Ctrl b" { Write 2; SwitchToMode "Normal"; }

        // Pane focus
        bind "h" "Left" { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "j" "Down" { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "k" "Up" { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "l" "Right" { MoveFocus "Right"; SwitchToMode "Normal"; }

        // Pane resize
        bind "a" { Resize "Increase Left"; SwitchToMode "Normal"; }
        bind "d" { Resize "Increase Down"; SwitchToMode "Normal"; }
        bind "e" { Resize "Increase Up"; SwitchToMode "Normal"; }
        bind "f" { Resize "Increase Right"; SwitchToMode "Normal"; }

        // Pane and tab management
        bind "s" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "v" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "x" { CloseFocus; SwitchToMode "Normal"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "c" { NewTab; SwitchToMode "Normal"; }
        bind "w" { GoToNextTab; SwitchToMode "Normal"; }
        bind "q" { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "g" { Detach; SwitchToMode "Normal"; }
        bind "r" { NextSwapLayout; SwitchToMode "Normal"; }
    }
}

default_shell "zsh"
pane_frames true

themes {
    nord {
        bg "#@THEME_BG1@"
        fg "#@THEME_FG@"
        black "#@THEME_BG1@"
        red "#@THEME_RED@"
        green "#@THEME_GREEN@"
        yellow "#@THEME_YELLOW@"
        blue "#@THEME_BLUE@"
        magenta "#@THEME_PURPLE@"
        cyan "#@THEME_CYAN@"
        white "#@THEME_FG1@"
        orange "#@THEME_ORANGE@"
    }
}
theme "nord"
