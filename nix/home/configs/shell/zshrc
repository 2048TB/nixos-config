############################################
# 终端模式安全恢复
############################################
# Yazi / Zellij / television 等 TUI 使用 kitty keyboard protocol；
# 异常退出时可能残留该模式，导致方向键输出 ;129A 等乱码。
# 每次 prompt 前发送 CSI > u 关闭 kitty 协议 + 重置 bracketed paste。
function __reset_terminal_modes() {
    printf '\e[>0u'   # 禁用 kitty keyboard protocol
    printf '\e[?2004h' # 确保 bracketed paste 正常
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd __reset_terminal_modes

############################################
# 历史记录设置
############################################
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt append_history
setopt share_history
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_reduce_blanks


############################################
# Yazi 文件管理器
############################################
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
}

############################################
# Claude Code 快捷命令
############################################
function ccv() {
    local env_vars=(
        "ENABLE_BACKGROUND_TASKS=true"
        "FORCE_AUTO_BACKGROUND_TASKS=true"
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=true"
        "CLAUDE_CODE_ENABLE_UNIFIED_READ_TOOL=true"
    )

    local claude_args=("--dangerously-skip-permissions")

    if [[ "$1" == "r" ]]; then
        claude_args+=("--resume")
    fi

    env "${env_vars[@]}" claude "${claude_args[@]}"
}

############################################
# Codex 快捷命令
############################################
function cdx() {
    if [[ "$1" == "r" ]]; then
        shift
        codex resume "$@"
        return
    fi

    codex --dangerously-bypass-approvals-and-sandbox "$@"
}

############################################
# Eza（现代版 `ls`）
############################################
if command -v eza >/dev/null 2>&1; then
    alias ls='eza'
    alias ll='eza -l'
    alias la='eza -la'
    alias lt='eza --tree'
fi

############################################
# GPG 的 TTY 设置（Git 签名需要）
############################################
if [ -n "$TTY" ]; then
    export GPG_TTY=$(tty)
fi

############################################
# mise shell activation
############################################
if command -v mise >/dev/null 2>&1; then
    eval "$(mise activate zsh)"
fi

############################################
# Television shell integration
############################################
if [[ -o interactive ]] && [[ -t 0 ]] && [[ -t 1 ]] && command -v tv >/dev/null 2>&1; then
    eval "$(tv init zsh)"
fi

# 全局搜索
frg() {
  local depth=""
  case "$1" in
    l|1)   depth="--max-depth 1" ;;   # 输入 frg l 或 frg 1 表示仅当前目录
  esac

  fzf --ansi \
    --bind "change:reload:
      if [[ -n {q} ]]; then
        rg $depth --line-number --no-heading --color=always {q};
      else
        rg $depth --files;
      fi || true" \
    --preview "bat --style=numbers --color=always --highlight-line {2} {1}" \
    --delimiter ":"
}
