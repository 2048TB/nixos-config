# River Classic configuration

riverctl background-color 0x@THEME_BG@
riverctl border-color-focused 0x@THEME_BLUE@
riverctl border-color-unfocused 0x@THEME_BG3@
riverctl border-color-urgent 0x@THEME_RED@
riverctl border-width 2
riverctl focus-follows-cursor normal
riverctl hide-cursor timeout 8
riverctl hide-cursor when-typing enabled
riverctl set-repeat 50 300
riverctl set-cursor-warp on-output-change
riverctl default-layout rivercarro

riverctl declare-mode locked
riverctl declare-mode normal
riverctl declare-mode passthrough

riverctl map normal Super Return spawn ghostty
riverctl map normal Super Space spawn fuzzel
riverctl map normal Super Q close
riverctl map normal Super+Shift E exit
riverctl map normal Super Tab toggle-float
riverctl map normal Super Z toggle-fullscreen
riverctl map normal Super Left focus-view left
riverctl map normal Super Right focus-view right
riverctl map normal Super Up focus-view up
riverctl map normal Super Down focus-view down
riverctl map normal Super S swap left
riverctl map normal Super G swap right
riverctl map normal Super D swap up
riverctl map normal Super F swap down
riverctl map normal Super+Shift Left swap left
riverctl map normal Super+Shift Right swap right
riverctl map normal Super+Shift Up swap up
riverctl map normal Super+Shift Down swap down
riverctl map normal Super H send-layout-cmd rivercarro "main-ratio -0.05"
riverctl map normal Super L send-layout-cmd rivercarro "main-ratio +0.05"
riverctl map normal Super Period focus-output next
riverctl map normal Super Comma focus-output previous
riverctl map normal Super+Shift Period send-to-output next
riverctl map normal Super+Shift Comma send-to-output previous
riverctl map normal Super P enter-mode passthrough
riverctl map passthrough Super P enter-mode normal
riverctl map normal Super+Shift X spawn lock-screen
riverctl map normal Super W spawn wallpaper-next
riverctl map normal Super Escape spawn wlogout-menu
riverctl map normal Super V spawn river-cliphist-menu
riverctl map normal Super A spawn "take-screenshot area"
riverctl map normal Super+Shift A spawn "take-screenshot screen"
riverctl map normal None Print spawn "take-screenshot area"
riverctl map normal Control Print spawn "take-screenshot screen"

riverctl map-pointer normal Super BTN_LEFT move-view
riverctl map-pointer normal Super BTN_MIDDLE toggle-float
riverctl map-pointer normal Super BTN_RIGHT resize-view

riverctl map normal None XF86AudioRaiseVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
riverctl map normal None XF86AudioLowerVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
riverctl map normal None XF86AudioMute spawn "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
riverctl map normal None XF86MonBrightnessUp spawn "brightnessctl --class=backlight set 5%+"
riverctl map normal None XF86MonBrightnessDown spawn "brightnessctl --class=backlight set 5%-"
riverctl map locked None XF86AudioRaiseVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
riverctl map locked None XF86AudioLowerVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
riverctl map locked None XF86AudioMute spawn "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"

for i in $(seq 1 9); do
  tags=$((1 << (i - 1)))
  riverctl map normal Super "$i" set-focused-tags "$tags"
  riverctl map normal Super+Shift "$i" set-view-tags "$tags"
  riverctl map normal Super+Control "$i" toggle-focused-tags "$tags"
  riverctl map normal Super+Shift+Control "$i" toggle-view-tags "$tags"
done

riverctl rule-add -app-id "pavucontrol" float
riverctl rule-add -app-id "nm-connection-editor" float
riverctl rule-add -app-id "org.gnome.Calculator" float
riverctl rule-add -app-id "org.gnome.FileRoller" float
riverctl rule-add -app-id "pinentry*" float
riverctl rule-add -app-id "imv" float

rivercarro -outer-gaps 6 -inner-gaps 6 &
