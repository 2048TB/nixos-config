// 此配置使用 KDL 格式：https://kdl.dev
// "/-" 用于注释掉后续节点。

// 这是主配置文件，负责包含分类后的子配置文件。
// 交互：输入设备、快捷键、窗口规则。
include "./interaction.kdl"
// 外观与显示：布局、动画、输出。
include "./appearance.kdl"
include "./outputs.kdl"

// Noctalia shell 使用 ~/.local/state/noctalia/config 中的可写持久配置；
// 启动改为官方当前推荐的 compositor autostart。
spawn-at-startup "wayland-session-env-sync"
// quickshell 目前会在加载 fcitx5 的 Qt input context 时崩溃；
// Noctalia 不需要输入法，单独取消此变量，避免影响其它 Qt 应用。
spawn-at-startup "env" "-u" "QT_IM_MODULE" "noctalia-shell"

debug {
    // 允许 Noctalia 的通知动作与窗口激活在 Niri 下正常工作。
    honor-xdg-activation-with-invalid-serial
}

cursor {
    // 设置光标主题与大小，并同时设置
    // `XCURSOR_THEME` 与 `XCURSOR_SIZE` 环境变量。
    // xcursor-theme "default"
    // xcursor-size 24
}

hotkey-overlay {
    // 取消注释以在启动时禁用“重要快捷键”弹窗。
    skip-at-startup
}

// 请求客户端省略客户端装饰（CSD），统一使用 server-side 边框。
// 启用或禁用后需重启应用才能生效。
prefer-no-csd

// 可更改截图保存路径。
// 路径开头的 ~ 会展开为主目录。
// 路径可用 strftime(3) 格式化，以写入截图日期与时间。
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// 也可设为 null 以禁用保存到磁盘。
// screenshot-path null
