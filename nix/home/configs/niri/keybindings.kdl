binds {
    // 按键由用 + 连接的修饰键组成，末尾是 XKB 键名。
    // 可使用 wev 等程序查找具体键名。
    //
    // “Mod” 是特殊修饰键：在 TTY 下等同 Super，在 winit 窗口下等同 Alt。
    //
    // 此处多数动作也可通过 `niri msg action do-something` 以程序方式调用。

    // Mod-Shift-/（通常等同 Mod-?）会显示重要快捷键列表。
    Mod+Shift+Slash { show-hotkey-overlay; }

    // 建议的程序启动快捷键：终端、应用启动器、锁屏。
    Mod+Return { spawn "ghostty"; }
    // 浮动终端（通过 --class 区分，由 windowrules 设为浮动）
    Mod+Shift+Return { spawn "ghostty" "--class=ghostty-float"; }

    // 启动器
    Mod+Space { spawn "fuzzel"; }
    XF86Search { spawn "fuzzel"; }

    // 文件管理器（对齐 Hyprland: Mod+E）
    Mod+E { spawn "nautilus"; }

    // 手动锁屏（对齐 Hyprland: Mod+Shift+L）
    Mod+Shift+L { spawn "lock-screen"; }

    // 使用 spawn-sh 运行 shell 命令，如需管道、多条命令等。
    // 注意：整条命令作为单个参数传递，原样交给 `sh -c`。
    // 例如：下面是切换屏幕阅读器（orca）的常见绑定。
    // Super+Alt+S allow-when-locked=true hotkey-overlay-title=null { spawn-sh "pkill orca || exec orca"; }

    // 音量键（allow-when-locked 锁屏时生效，--limit 1.0 限制上限 100%）
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.01+ --limit 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.01-"; }
    XF86AudioMute allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // 媒体键（playerctl MPRIS）
    XF86AudioPlay allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext allow-when-locked=true { spawn-sh "playerctl next"; }

    // 屏幕亮度
    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "1%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "1%-"; }

    // 键盘背光
    XF86KbdBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--device=kbd_backlight" "set" "10%+"; }
    XF86KbdBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--device=kbd_backlight" "set" "10%-"; }

    // 打开/关闭概览：工作区与窗口的缩略视图。
    // 也可将鼠标移到左上角热区，
    // 或在触控板上四指上滑。
    Mod+O { toggle-column-tabbed-display; }

    // 交换为：方向键聚焦，HJKL 移动窗口/列
    Mod+Left { focus-column-left; }
    Mod+Down { focus-window-or-workspace-down; }
    Mod+Up { focus-window-or-workspace-up; }
    Mod+Right { focus-column-right; }
    Mod+H { move-column-left; }
    Mod+J { move-window-down; }
    Mod+K { move-window-up; }
    Mod+L { move-column-right; }
    Mod+Ctrl+Left { move-column-left; }
    Mod+Ctrl+Down { move-window-down; }
    Mod+Ctrl+Up { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    // 多显示器（对齐 Hyprland 组合键，不使用别名）
    Mod+Shift+Alt+H { focus-monitor-left; }
    Mod+Shift+Alt+J { focus-monitor-down; }
    Mod+Shift+Alt+K { focus-monitor-up; }
    Mod+Shift+Alt+L { focus-monitor-right; }

    Mod+Ctrl+H { move-window-to-monitor-left; }
    Mod+Ctrl+J { move-window-to-monitor-down; }
    Mod+Ctrl+K { move-window-to-monitor-up; }
    Mod+Ctrl+L { move-window-to-monitor-right; }

    Mod+Ctrl+Shift+H { move-workspace-to-monitor-left; }
    Mod+Ctrl+Shift+J { move-workspace-to-monitor-down; }
    Mod+Ctrl+Shift+K { move-workspace-to-monitor-up; }
    Mod+Ctrl+Shift+L { move-workspace-to-monitor-right; }

    "Mod+Page_Down"      { focus-workspace-down; }
    "Mod+Page_Up" { focus-workspace-up; }
    "Mod+Ctrl+Page_Down" { move-column-to-workspace-down; }
    "Mod+Ctrl+Page_Up" { move-column-to-workspace-up; }
    // 对齐 Hyprland：B/N 发送当前窗口到上/下一个工作区
    Mod+B { move-window-to-workspace-up; }
    Mod+N { move-window-to-workspace-down; }
    "Mod+Shift+Page_Down" { move-workspace-down; }
    "Mod+Shift+Page_Up" { move-workspace-up; }
    Mod+Alt+Left  { focus-workspace-up; }
    Mod+Alt+Right { focus-workspace-down; }
    Mod+Alt+Down  { focus-workspace 99; }

    // 按住 Mod 的滚轮操作（官方默认推荐模式）。
    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    // 可按索引引用工作区。但 niri 使用动态工作区系统，
    // 这些命令属于“尽力而为”。当索引大于当前工作区数量时，
    // 会指向最底部的（空）工作区。
    //
    // 例如有 2 个工作区 + 1 个空位时，索引 3、4、5 等都会指向第 3 个工作区。
    // 工作区直达：扩展到常用 1-9
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    // 将当前列直接投递到指定工作区 1-9
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }
    // 将当前窗口直接投递到指定工作区 1-9
    Mod+Alt+1 { move-window-to-workspace 1; }
    Mod+Alt+2 { move-window-to-workspace 2; }
    Mod+Alt+3 { move-window-to-workspace 3; }
    Mod+Alt+4 { move-window-to-workspace 4; }
    Mod+Alt+5 { move-window-to-workspace 5; }
    Mod+Alt+6 { move-window-to-workspace 6; }
    Mod+Alt+7 { move-window-to-workspace 7; }
    Mod+Alt+8 { move-window-to-workspace 8; }
    Mod+Alt+9 { move-window-to-workspace 9; }

    // 在当前与上一个工作区之间切换焦点。
    Mod+Tab { focus-workspace-previous; }

    // 新建工作区（类别）并切换到它：
    // 使用动态工作区，跳到“最底部空工作区”。
    Mod+Shift+N { focus-workspace 99; }
    Mod+Ctrl+Shift+N { focus-workspace 99; }

    // 以下绑定用于在列内/列外移动焦点窗口。
    // 如果窗口独立存在，将其并入旁边的列；
    // 若已在列内，则将其移出。
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    // 从右侧列吸入一个窗口到当前列底部。
    Mod+D { consume-window-into-column; }
    // 将当前列底部窗口移到右侧。
    Mod+F { expel-window-from-column; }

    Mod+R { switch-preset-column-width; }
    // 也可按反向顺序循环预设。
    // Mod+R { switch-preset-column-width-back; }
    Mod+Shift+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }
    Mod+Z { maximize-column; }
    Mod+Shift+M { maximize-window-to-edges; }
    // 官方 Screencasting 推荐：应用“窗口化全屏”（fake fullscreen）
    Mod+Ctrl+Shift+F { toggle-windowed-fullscreen; }

    // 将当前列扩展到未被其他完整可见列占用的空间，
    // 使其“填满剩余空间”。
    Mod+Ctrl+F { expand-column-to-available-width; }

    // 将所有完整可见的列居中显示（为 Ctrl+C 让位给 cliphist）
    Mod+Shift+C { center-column; }
    Mod+Ctrl+Shift+C { center-visible-columns; }

    // 更精细的宽度调整。
    // 此命令还可以：
    // * 以像素设置宽度："1000"
    // * 以像素增减宽度："-5" 或 "+5"
    // * 以屏幕宽度百分比设置："25%"
    // * 以百分比增减宽度："-10%" 或 "+10%"
    // 像素尺寸使用逻辑/缩放像素。例如输出缩放为 2.0 时，
    // set-column-width "100" 会让列占用 200 物理像素。
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    // 与其他窗口同列时的更精细高度调整。
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // 在浮动与平铺布局间切换当前窗口。
    Mod+C { toggle-window-floating; }

    // 在浮动窗口与平铺窗口之间切换焦点。
    Mod+V { switch-focus-between-floating-and-tiling; }

    // 快速上下移动当前窗口。
    Mod+S { move-window-down; }
    Mod+G { move-window-up; }

    // 全屏当前窗口。
    Mod+X { fullscreen-window; }

    // 切换列的标签页显示模式。
    // 该列窗口将以纵向标签显示，
    // 而非堆叠在一起。
    Mod+W repeat=false { toggle-overview; }

    // 切换布局的动作。
    // 注意：若取消注释，请确保上面的 xkb 选项中没有相同快捷键。
    // 同一快捷键若同时存在，会导致按下时切换两次（xkb 一次、niri 一次），从而失效。
    Mod+Alt+Space { switch-layout "next"; }
    Mod+Alt+Shift+Space { switch-layout "prev"; }
    // Mod+Space       { switch-layout "next"; }
    // Mod+Shift+Space { switch-layout "prev"; }

    Print { screenshot; }
    // 对齐 Hyprland: Mod+A 区域截图
    Mod+A { spawn "river-screenshot" "area"; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

    // 远程桌面客户端与软件 KVM 等应用可能请求 niri 停止处理此处快捷键，
    // 以便将按键原样转发到远端机器。
    // 建议绑定一个“逃生”快捷键切换抑制器，
    // 避免故障应用把会话卡住。
    //
    // allow-inhibiting=false 也可用于其他绑定，
    // 确保即使抑制器开启，niri 仍处理它们。
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // 退出动作会显示确认对话框，避免误退出。
    Mod+Shift+E { quit; }
    Ctrl+Alt+Delete { quit; }
    Mod+Q repeat=false { close-window; }

    // 关闭显示器电源。要恢复，移动鼠标或按任意键。
    Mod+Shift+P { power-off-monitors; }

    // 实用快捷键（对齐 Hyprland）
    Mod+Ctrl+C { spawn "river-cliphist-menu"; }
    Mod+Ctrl+B { spawn-sh "pkill -SIGUSR1 waybar || true"; }
    Mod+Ctrl+S { spawn "pavucontrol"; }
    Mod+Ctrl+E { spawn "wlogout-menu"; }
}
